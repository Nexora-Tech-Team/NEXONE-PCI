ENV=production
COMPOSE_PROJECT_NAME=nexone-pci

JWT_SECRET=nexone-pci-local-dev-secret-change-before-production
JWT_EXP_HOURS=24
APP_URL=https://nexone-pci.nexoratech.co
UPLOAD_DIR=./uploads

POSTGRES_USER=nexone_pci
POSTGRES_PASSWORD=nexone_pci123
POSTGRES_DB=nexone_pci_db

DB_HOST=postgres
DB_PORT=5432
DB_USER=nexone_pci
DB_PASSWORD=nexone_pci123
DB_NAME=nexone_pci_db

VITE_API_URL=/api/v1

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
